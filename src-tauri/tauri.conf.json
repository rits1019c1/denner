{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Denner",
  "version": "1.7.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../src-web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../src-web && npm run dev",
    "beforeBuildCommand": "cd ../src-web && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Denner Desktop",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
